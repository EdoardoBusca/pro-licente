# ─── Estate Vantage — Backend Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is gitignored and NEVER committed.

# Get your Groq API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Supabase (or any Postgres) connection string
DATABASE_URL=postgresql://postgres:yourpassword@db.xxxx.supabase.co:5432/postgres

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-string

# Default admin password seeded on first run (change after first login)
ADMIN_DEFAULT_PASSWORD=change-me-on-first-login

# Optional overrides
FRONTEND_ORIGIN=http://localhost:3000
SCHEMA_VALID_RATIO=0.90
